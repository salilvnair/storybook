# ─── Server ────────────────────────────────────────────────────────────────
PORT=8787

# ─── LLM provider (OpenAI-compatible chat completions) ───────────────────────
# DeepSeek is the default. Any OpenAI-compatible endpoint works (Ollama, LM Studio,
# OpenAI, Together, Groq, etc.) — just point LLM_BASE_URL + LLM_MODEL at it.
LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-deepseek-key-here
# Optional: 'openai' (default) or 'anthropic' wire format
LLM_TYPE=openai

# ─── RunPod Ideogram 4 server (your deployed experiments/cuda-id4 api_server.py) ─
# The proxy URL RunPod gives you, e.g. https://abc123-8080.proxy.runpod.net
RUNPOD_URL=https://REPLACE-ME.proxy.runpod.net

# Image generation defaults
# 1:1 — square illustrations fill the right half of each picture-book spread
# (classic board-book layout: text card on the left, full-bleed art on the right).
IMAGE_PRESET=DEFAULT
IMAGE_ASPECT_RATIO=1:1
IMAGE_MAGIC=true
